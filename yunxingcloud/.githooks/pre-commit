#!/bin/bash
# ============================================
# yunxingcloud pre-commit hook
# 检查: 前端 ESLint + TypeScript + 后端编译
# ============================================
set -e

ROOT="$(git rev-parse --show-toplevel)"
STAGED_JAVA=$(git diff --cached --name-only --diff-filter=ACM | grep '\.java$' || true)
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|vue)$' || true)

echo "========================================"
echo " Pre-commit Check"
echo "========================================"

# 1. 前端检查
if [ -n "$STAGED_TS" ]; then
    echo "[1/3] 前端 TypeScript 检查..."
    cd "$ROOT/frontend"
    npx vue-tsc --noEmit 2>/dev/null || {
        echo "TypeScript 检查失败，请修复后提交"
        exit 1
    }
    echo "  ✓ TypeScript OK"

    if [ -f "$ROOT/frontend/node_modules/.bin/eslint" ]; then
        echo "  ESLint..."
        npx eslint $(echo "$STAGED_TS" | sed "s|^|$ROOT/frontend/|") --max-warnings 5 2>/dev/null || true
    fi
else
    echo "[1/3] 无前端变更，跳过"
fi

# 2. 后端编译检查
if [ -n "$STAGED_JAVA" ]; then
    echo "[2/3] 后端编译检查..."
    cd "$ROOT"
    ./mvnw compile -DskipTests -q 2>&1 | tail -1 || {
        echo "Maven 编译失败，请修复后提交"
        exit 1
    }
    echo "  ✓ Maven OK"
else
    echo "[2/3] 无后端变更，跳过"
fi

# 3. 敏感信息检查
echo "[3/3] 敏感信息检查..."
if git diff --cached | grep -iE "password\s*=\s*['\"][^E][^N][^C].*['\"]" > /dev/null 2>&1; then
    echo "  ⚠ 警告: 检测到可能的硬编码密码"
fi
echo "  ✓ 敏感信息 OK"

echo "========================================"
echo " Pre-commit 通过 ✓"
echo "========================================"