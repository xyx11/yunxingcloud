{
  "dashboard": {
    "title": "yunxingcloud 全局监控",
    "uid": "yunxingcloud-v2",
    "panels": [
      {
        "title": "QPS (6 服务)",
        "targets": [
          { "expr": "rate(http_server_requests_seconds_count[1m])", "legendFormat": "{{job}}" }
        ],
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
      },
      {
        "title": "P95 响应时间",
        "targets": [
          { "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket[5m]))", "legendFormat": "{{job}}" }
        ],
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
      },
      {
        "title": "JVM 堆内存",
        "targets": [
          { "expr": "jvm_memory_used_bytes{area=\"heap\"} / jvm_memory_max_bytes", "legendFormat": "{{job}}" }
        ],
        "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 }
      },
      {
        "title": "5xx 错误率",
        "targets": [
          { "expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]) / rate(http_server_requests_seconds_count[5m])", "legendFormat": "{{job}}" }
        ],
        "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 }
      },
      {
        "title": "业务指标: 订单数",
        "targets": [
          { "expr": "rate(yunxingcloud_orders_created_total[5m])", "legendFormat": "创建" },
          { "expr": "rate(yunxingcloud_orders_paid_total[5m])", "legendFormat": "支付" },
          { "expr": "rate(yunxingcloud_orders_canceled_total[5m])", "legendFormat": "取消" }
        ],
        "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 }
      },
      {
        "title": "库存预警",
        "targets": [
          { "expr": "yunxingcloud_inventory_alerts_total", "legendFormat": "预警数" }
        ],
        "gridPos": { "x": 0, "y": 14, "w": 8, "h": 5 }
      },
      {
        "title": "DB 连接池使用率",
        "targets": [
          { "expr": "hikaricp_connections_active / hikaricp_connections_max", "legendFormat": "{{job}}" }
        ],
        "gridPos": { "x": 8, "y": 14, "w": 8, "h": 5 }
      },
      {
        "title": "限流命中率",
        "targets": [
          { "expr": "rate(ratelimit_rejected_total[5m]) / rate(ratelimit_total[5m])", "legendFormat": "{{key}}" }
        ],
        "gridPos": { "x": 16, "y": 14, "w": 8, "h": 5 }
      }
    ],
    "templating": {
      "list": [
        { "name": "service", "query": "label_values(job)", "type": "query" }
      ]
    }
  },
  "alertChannels": {
    "dingtalk": {
      "webhook": "https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN",
      "template": "{ \"msgtype\": \"text\", \"text\": { \"content\": \"[yunxingcloud] {{ .Status }}: {{ .Alerts | len }} alerts\\n{{ range .Alerts }}{{ .Labels.alertname }}: {{ .Annotations.summary }}\\n{{ end }}\" } }"
    },
    "feishu": {
      "webhook": "https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN",
      "template": "{ \"title\": \"yunxingcloud Alert\", \"text\": \"{{ .Status }}: {{ .Alerts | len }} alerts\\n{{ range .Alerts }}{{ .Labels.alertname }}: {{ .Annotations.summary }}\\n{{ end }}\" }"
    }
  }
}