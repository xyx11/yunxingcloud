# ============================================
# yunxingcloud 环境变量模板
# 复制为 .env 并修改值:
#   cp .env.example .env
# ============================================

# ---- 数据库 ----
DB_URL=jdbc:mysql://localhost:3306/yunxingcloud_core?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=change-me
DB_HOST=localhost

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT 认证 ----
JWT_SECRET=change-me-to-a-random-256-bit-string

# ---- OAuth2 ----
OAUTH2_CLIENT_ID=yunxingcloud-client
OAUTH2_CLIENT_SECRET=change-me
OAUTH2_REDIRECT_URI=http://localhost:9090/callback

# ---- Nacos ----
NACOS_SERVER=127.0.0.1:8848
NACOS_NAMESPACE=

# ---- Sentinel ----
SENTINEL_DASHBOARD=127.0.0.1:8082

# ---- SMTP 邮件 ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@yunxingcloud.com
SMTP_PASSWORD=

# ---- 微信支付 (留空=mock模式) ----
WECHAT_CLIENT_ID=
WECHAT_CLIENT_SECRET=
PAYMENT_WECHAT_MERCHANT_ID=
PAYMENT_WECHAT_API_V3_KEY=

# ---- 支付宝 (留空=mock模式) ----
ALIPAY_CLIENT_ID=
ALIPAY_CLIENT_SECRET=
PAYMENT_ALIPAY_APP_ID=
PAYMENT_ALIPAY_PRIVATE_KEY=
PAYMENT_ALIPAY_PUBLIC_KEY=

# ---- 短信 (留空=mock模式) ----
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=yunxingcloud
SMS_TEMPLATE_CODE=

# ---- 对象存储 (留空=mock/本地模式) ----
OSS_ENDPOINT=
OSS_BUCKET=yunxingcloud
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

# ---- Docker 部署 ----
DOCKER_REGISTRY=
TAG=latest
DB_PASSWORD=change-me
GRAFANA_PASSWORD=admin

# ---- 应用 ----
SPRING_PROFILES_ACTIVE=dev
APP_BASE_URL=http://localhost:8080
APP_PORT=8080
CANARY_WEIGHT=10